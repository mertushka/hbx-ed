{
	"name": "hbx-ed",
	"private": true,
	"version": "0.0.9",
	"description": "Browser-based HaxBall stadium editor for .hbs files.",
	"license": "MIT",
	"author": "mertushka",
	"homepage": "https://github.com/mertushka/hbx-ed#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mertushka/hbx-ed.git"
	},
	"bugs": {
		"url": "https://github.com/mertushka/hbx-ed/issues"
	},
	"type": "module",
	"engines": {
		"node": "^20.19.0 || ^22.12.0 || >=24.0.0"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"check": "tsc --noEmit && biome check . && vitest run",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run lint && npm run typecheck",
		"pre-push": "npm run check && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@cloudflare/vite-plugin": "^1.38.0",
		"@vitest/coverage-v8": "^4.1.6",
		"jsdom": "^29.1.1",
		"simple-git-hooks": "^2.13.1",
		"typescript": "~6.0.2",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"wrangler": "^4.94.0"
	},
	"dependencies": {
		"json5": "^2.2.3"
	}
}
